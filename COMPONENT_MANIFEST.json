{
  "project_name": "Minecraft-MiniWorld Protocol Bridge",
  "version": "1.0.0",
  "description": "实现迷你世界与Minecraft全端互通的协议桥接方案",
  "directories": {
    "project": "https://github.com/StarsailsClover/Minecraft.and.MiniWorldCreata-CrossPlatform-CrossPlay",
    "external": "https://github.com/StarsailsClover/MnMCPResources"
  },
  "components": {
    "tools": {
      "location": "项目目录/tools",
      "external": false,
      "description": "逆向工程工具集",
      "files": {
        "apktool.jar": {
          "description": "APK反编译工具",
          "min_size": "20MB"
        },
        "apktool.bat": {
          "description": "APK工具启动脚本"
        },
        "jadx/": {
          "description": "Java反编译器",
          "type": "directory"
        },
        "frida-server.xz": {
          "description": "Frida动态分析服务端",
          "min_size": "10MB"
        },
        "python_libs/": {
          "description": "Python依赖库",
          "type": "directory"
        }
      }
    },
    "server": {
      "location": "项目目录/server",
      "external": false,
      "description": "Minecraft Java服务端",
      "files": {
        "paper/paper-1.20.6-151.jar": {
          "description": "PaperMC服务端",
          "min_size": "40MB"
        },
        "paper/paper.jar": {
          "description": "PaperMC软链接"
        },
        "plugins/Geyser-Spigot.jar": {
          "description": "GeyserMC互通插件",
          "min_size": "10MB"
        },
        "plugins/floodgate-spigot.jar": {
          "description": "Floodgate认证插件",
          "min_size": "1MB"
        },
        "fabric/fabric-installer.jar": {
          "description": "Fabric模组加载器"
        },
        "mods/fabric-api-0.98.0.jar": {
          "description": "Fabric API",
          "min_size": "1MB"
        }
      }
    },
    "apk_downloads": {
      "location": "外部目录/apk_downloads",
      "external": true,
      "description": "APK文件（大文件存储区）",
      "files": {
        "miniworld_cn_1.53.1.apk": {
          "description": "迷你世界国服",
          "size": "1.6GB",
          "status": "已下载"
        },
        "miniworld_en_1.7.15.apk": {
          "description": "MiniWorld: Creata外服",
          "size": "~1.2GB",
          "status": "待下载"
        },
        "minecraft_bedrock_1.20.60.apk": {
          "description": "Minecraft基岩版",
          "size": "~200MB",
          "status": "需正版购买"
        }
      },
      "decompiled": {
        "miniworld_cn_decompiled/": {
          "description": "迷你世界国服反编译输出",
          "status": "反编译进行中"
        }
      }
    },
    "docs": {
      "location": "项目目录/docs",
      "external": false,
      "description": "技术文档",
      "files": {
        "TechnicalDocument.md": "技术架构文档",
        "ProjectPlan.md": "项目规划文档",
        "README.md": "文档目录说明"
      }
    },
    "reverse_engineering": {
      "location": "项目目录/reverse_engineering",
      "external": false,
      "description": "逆向工程会话记录",
      "files": {
        "session_001_terminal_log.md": "工具安装记录",
        "session_002_terminal_log.md": "服务端搭建记录",
        "session_003_terminal_log.md": "APK下载指南",
        "session_004_terminal_log.md": "大文件管理记录"
      }
    }
  },
  "scripts": {
    "path_resolver.py": {
      "description": "统一路径解析工具",
      "usage": "import path_resolver; path = path_resolver.get_apk_path('miniworld_cn_1.53.1.apk')"
    },
    "check_and_fix_components.py": {
      "description": "组件完整性检查和修复"
    },
    "move_large_files.py": {
      "description": "大文件移动工具"
    },
    "decompile_miniworld_cn.py": {
      "description": "迷你世界国服APK反编译"
    }
  },
  "gitignore_rules": [
    "MnMCPResources/ - 外部资源目录",
    "*.apk - APK文件",
    "*_decompiled/ - 反编译输出",
    "*.log - 日志文件",
    "__pycache__/ - Python缓存"
  ],
  "notes": [
    "超过100MB的文件存储在外部目录 MnMCPResources/",
    "使用.location文件记录大文件实际位置",
    "所有脚本应使用path_resolver.py获取路径",
    "Git提交时不会包含大文件和外部目录",
    "新成员需要手动下载大文件或从外部目录复制"
  ],
  "setup_instructions": {
    "new_member": [
      "1. 克隆GitHub仓库（小文件）",
      "2. 创建外部目录: C:\\Users\\<用户名>\\Documents\\Coding\\MnMCPResources",
      "3. 下载APK文件（参考apk_downloads/MANUAL_DOWNLOAD_GUIDE.md）",
      "4. 运行path_resolver.py验证路径",
      "5. 运行check_and_fix_components.py检查完整性"
    ],
    "existing_member": [
      "1. 运行check_and_fix_components.py检查更新",
      "2. 同步外部目录中的大文件"
    ]
  }
}
